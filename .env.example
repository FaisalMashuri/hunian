# Salin ke `.env.local` lalu isi. `.env.local` gitignored.

# Auth.js (NextAuth) — AUTH_SECRET: generate kuat dgn `openssl rand -base64 32`
AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI (AI extraction)
OPENAI_API_KEY=

# Supabase (data + storage only — service role HANYA server-side)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps / Places (batasi by referrer/IP di console)
GOOGLE_MAPS_API_KEY=

# URL situs untuk metadata SEO absolut (OG image, canonical, sitemap). Mis: https://hunian.app
# Opsional di dev (fallback localhost). WAJIB di produksi agar OG image & canonical benar.
NEXT_PUBLIC_SITE_URL=
