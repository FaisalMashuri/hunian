# Salin file ini jadi `.env` lalu isi key yang kamu punya.
# `.env` sudah di-gitignore — jangan commit key.

# Wajib untuk uji GPT-4o mini (keputusan stack tim)
OPENAI_API_KEY=

# Opsional — untuk pembanding Claude Haiku
ANTHROPIC_API_KEY=

# Opsional override model id
